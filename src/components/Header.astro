                        fill="#00BD7B"></path>
                </g>
                <defs>
                    <clipPath id="clip0_logo">
                        <rect width="118" height="26" fill="white"></rect>
                    </clipPath>
                </defs>
            </svg>
        </a>

        <div
            class="flex items-center justify-end gap-12 flex-1 max-[900px]:hidden"
        >
            <a
                href="/platform"
                class:list={[
                    "nav-link font-medium text-[18px] leading-normal text-secondary no-underline whitespace-nowrap transition-colors hover:text-primary",
                    { active: pathname.startsWith("/platform") },
                ]}>The platform</a
            >

            <a
                href="/blog"
                class:list={[
                    "nav-link font-medium text-[18px] leading-normal text-secondary no-underline whitespace-nowrap transition-colors hover:text-primary",
                    { active: pathname.startsWith("/blog") },
                ]}>Blog</a
            >

            <a
                href="/#waitlist"
                class="inline-flex items-center justify-center px-4 py-3 bg-accent-dark text-white font-medium text-base leading-normal no-underline rounded-xl whitespace-nowrap shrink-0 border border-transparent transition-colors hover:bg-[#01593A] hover:border-[#01734B]"
                >Join the waitlist</a
            >
        </div>

        <!-- Hamburger button -->
        <button
            id="mobile-menu-btn"
            class="hidden max-[900px]:flex items-center justify-center bg-transparent border-0 cursor-pointer p-1"
            aria-label="Open menu"
            aria-expanded="false"
        >
            <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
            >
                <path
                    d="M3 6H21M3 12H21M3 18H21"
                    stroke="#D1D8FF"
                    stroke-width="2"
                    stroke-linecap="round"></path>
            </svg>
        </button>
    </nav>
</header>

<!-- Overlay -->
<div
    id="drawer-overlay"
    class="fixed inset-0 bg-black/50 z-[150] opacity-0 pointer-events-none transition-opacity duration-300"
>
</div>

<!-- Mobile drawer -->
<div
    id="mobile-drawer"
    class="fixed top-0 right-0 h-full w-[280px] bg-bg z-[200] flex flex-col translate-x-full transition-transform duration-300 ease-in-out"
>
    <!-- Drawer header -->
    <div
        class="flex items-center justify-between px-5 py-4 border-b border-border"
    >
        <a
            href="/"
            class="flex items-center shrink-0 no-underline"
            aria-label="Cabin home"
        >
            <svg
                width="88"
                height="20"
                viewBox="0 0 118 26"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
            >
                <g clip-path="url(#clip0_drawer_logo)">
                    <path
                        d="M28.1589 12.6921V10.4464C28.1589 7.89625 26.8018 5.5892 24.703 4.57107L16.3923 0.537047C14.9159 -0.179016 13.2237 -0.179016 11.7474 0.537047L6.96415 2.85854V0.0183532H2.64959V5.04042C0.999131 6.20899 -0.0192871 8.2633 -0.0192871 10.4464V21.0128C-0.0192871 23.7628 2.0259 26 4.53975 26H23.5999C26.1137 26 28.1589 23.7628 28.1589 21.0128V18.394H23.8444V21.0128C23.8444 21.4208 23.6357 21.629 23.5999 21.6459L4.56002 21.6483C4.50397 21.629 4.29527 21.4208 4.29527 21.0128V10.4464C4.29527 9.57268 4.70193 8.78802 5.30654 8.49437L13.6173 4.46035C13.9178 4.31473 14.2219 4.31473 14.5224 4.46035L22.8331 8.49437C23.4377 8.78802 23.8444 9.57268 23.8444 10.4464V12.6921H28.1589Z"
                        fill="#00BD7B"></path>
                    <path
                        d="M35.6162 16.6275C35.6162 12.1885 39.2257 8.48583 43.9564 8.54589C46.9896 8.57591 49.7801 9.95394 51.1753 13.1066L46.656 15.5561C46.1706 14.5147 45.1997 13.7198 43.9564 13.7198C42.2276 13.7198 41.0751 15.0046 41.0751 16.6275C41.0751 18.2489 42.2276 19.5653 43.9564 19.5653C45.1997 19.5653 46.1706 18.7688 46.656 17.729L51.1753 20.1769C49.7801 23.3296 46.9896 24.7076 43.9564 24.7376C39.2257 24.7993 35.6162 21.065 35.6162 16.6275Z"
                        fill="#00BD7B"></path>
                    <path
                        d="M52.6897 16.6275C52.6897 12.1885 56.2992 8.51587 61.0299 8.51587C65.8827 8.51587 69.3716 11.9451 69.3716 16.6275V24.311H64.215V23.1779C63.2441 24.1877 61.8802 24.7708 60.12 24.7708C55.6916 24.7693 52.6897 21.0951 52.6897 16.6275ZM63.9127 16.6576C63.9127 15.0346 62.7602 13.6882 61.0299 13.6882C59.3011 13.6882 58.1485 15.0346 58.1485 16.6576C58.1485 18.2489 59.3011 19.5954 61.0299 19.5954C62.7602 19.5969 63.9127 18.2489 63.9127 16.6576Z"
                        fill="#00BD7B"></path>
                    <path
                        d="M72.3999 16.6876V1.96393H77.8603V9.4024C78.7999 8.88248 79.9227 8.54588 81.0454 8.54588C85.8685 8.54588 89.0834 11.7902 89.0834 16.6876C89.0834 21.1251 85.4739 24.7692 80.7432 24.7692C75.8888 24.7692 72.3999 21.3716 72.3999 16.6876ZM83.6229 16.6576C83.6229 15.0646 82.4704 13.7198 80.7416 13.7198C79.0128 13.7198 77.8603 15.0662 77.8603 16.6576C77.8603 18.2789 79.0128 19.5953 80.7416 19.5953C82.4704 19.5953 83.6229 18.2805 83.6229 16.6576Z"
                        fill="#00BD7B"></path>
                    <path
                        d="M91.5654 4.0768C91.5654 2.27051 93.0515 0.770813 94.8414 0.770813C96.6312 0.770813 98.1173 2.27051 98.1173 4.0768C98.1173 5.88308 96.6312 7.38279 94.8414 7.38279C93.0515 7.38279 91.5654 5.88308 91.5654 4.0768ZM97.5708 9.00575V24.311H92.1119V9.00575H97.5708Z"
                        fill="#00BD7B"></path>
                    <path
                        d="M106.669 17.4541V24.311H101.208V16.7808C101.208 12.2801 103.817 8.5459 109.428 8.5459C115.039 8.5459 117.648 12.2801 117.648 16.7808V24.311H112.189V17.4541C112.189 15.5261 111.431 13.9031 109.428 13.9031C107.427 13.9031 106.669 15.5245 106.669 17.4541Z"
                        fill="#00BD7B"></path>
                </g>
                <defs>
                    <clipPath id="clip0_drawer_logo">
                        <rect width="118" height="26" fill="white"></rect>
                    </clipPath>
                </defs>
            </svg>
        </a>
        <button
            id="drawer-close-btn"
            class="flex items-center justify-center bg-transparent border-0 cursor-pointer p-1"
            aria-label="Close menu"
        >
            <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
            >
                <path
                    d="M6 6L18 18M6 18L18 6"
                    stroke="#D1D8FF"
                    stroke-width="2"
                    stroke-linecap="round"></path>
            </svg>
        </button>
    </div>

    <!-- Drawer nav links -->
    <nav class="flex flex-col flex-1 px-5 py-6 gap-1">
        <a
            href="/platform"
            class:list={[
                "drawer-link font-medium text-[18px] leading-normal text-secondary no-underline px-3 py-3 rounded-xl transition-colors hover:text-primary hover:bg-white/5",
                { "text-primary": pathname.startsWith("/platform") },
            ]}>The platform</a
        >
        <a
            href="/blog"
            class:list={[
                "drawer-link font-medium text-[18px] leading-normal text-secondary no-underline px-3 py-3 rounded-xl transition-colors hover:text-primary hover:bg-white/5",
                { "text-primary": pathname.startsWith("/blog") },
            ]}>Blog</a
        >
    </nav>

    <!-- Drawer footer CTA -->
    <div class="px-5 py-6 border-t border-border">
        <a
            href="/#waitlist"
            class="inline-flex items-center justify-center w-full px-4 py-3 bg-accent-dark text-white font-medium text-base leading-normal no-underline rounded-xl border border-transparent transition-colors hover:bg-[#01593A] hover:border-[#01734B]"
            >Join the waitlist</a
        >
    </div>
</div>

<style>
    .nav-link.active {
        color: #d1d8ff;
    }
</style>

<script>
    const menuBtn = document.getElementById("mobile-menu-btn");
    const closeBtn = document.getElementById("drawer-close-btn");
    const drawer = document.getElementById("mobile-drawer");
    const overlay = document.getElementById("drawer-overlay");

    function openDrawer() {
        drawer?.classList.remove("translate-x-full");
        overlay?.classList.remove("opacity-0", "pointer-events-none");
        overlay?.classList.add("opacity-100");
        document.body.style.overflow = "hidden";
        menuBtn?.setAttribute("aria-expanded", "true");
    }

    function closeDrawer() {
        drawer?.classList.add("translate-x-full");
        overlay?.classList.add("opacity-0", "pointer-events-none");
        overlay?.classList.remove("opacity-100");
        document.body.style.overflow = "";
        menuBtn?.setAttribute("aria-expanded", "false");
    }

    menuBtn?.addEventListener("click", openDrawer);
    closeBtn?.addEventListener("click", closeDrawer);
    overlay?.addEventListener("click", closeDrawer);

    // Close drawer on nav link click
    drawer?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", closeDrawer);
    });
</script>
