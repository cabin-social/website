---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import ScrollIndicator from "../components/ScrollIndicator.astro";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate } = Astro.props;

const pageUrl = Astro.url.href;
const encodedUrl = encodeURIComponent(pageUrl);
const encodedTitle = encodeURIComponent(title);
const twitterShare = `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`;
const blueskyShare = `https://bsky.app/intent/compose?text=${encodedTitle}%20${encodedUrl}`;
const facebookShare = `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`;
const linkedinShare = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
---

<!doctype html>
<html
    lang="en"
    class="h-screen overflow-hidden max-[900px]:h-auto max-[900px]:overflow-auto"
>
    <head>
        <BaseHead title={title} description={description} />
    </head>

    <body class="bg-bg h-full flex flex-col max-[900px]:h-auto">
        <Header />

        <main
            class="flex-1 min-h-0 w-full max-w-[1280px] mx-auto flex flex-col"
        >
            <div
                class="flex-1 min-h-0 overflow-y-auto py-16 px-16 max-[900px]:px-6 max-[600px]:px-5"
            >
                <article class="max-w-[600px] mx-auto">
                    <a
                        href="/blog"
                        class="text-secondary hover:text-primary text-[16px] mb-8 inline-flex items-center gap-2 transition-colors"
                    >
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 20 20"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                d="M2.21885 9.46876C1.9251 9.76251 1.9251 10.2375 2.21885 10.5281L7.46885 15.7813C7.7626 16.075 8.2376 16.075 8.52822 15.7813C8.81885 15.4875 8.82197 15.0125 8.52822 14.7219L4.55947 10.75H17.2501C17.6657 10.75 18.0001 10.4156 18.0001 10C18.0001 9.58439 17.6657 9.25001 17.2501 9.25001H4.55947L8.53135 5.28126C8.8251 4.98751 8.8251 4.51251 8.53135 4.22189C8.2376 3.93126 7.7626 3.92814 7.47197 4.22189L2.21885 9.46876Z"
                                fill="#7883BE"></path>
                        </svg>
                        Back to blog
                    </a>

                    <header>
                        <h1
                            class="text-primary font-bold text-[44px] leading-[1.1] mb-4 max-[900px]:text-[32px]"
                        >
                            {title}
                        </h1>

                        <p class="text-secondary text-[16px] mb-8">
                            <FormattedDate date={pubDate} />
                            {
                                updatedDate && (
                                    <span class="italic">
                                        {" "}
                                        · Last updated on{" "}
                                        <FormattedDate date={updatedDate} />
                                    </span>
                                )
                            }
                        </p>

                        <hr class="border-border mb-8" />
                    </header>

                    <div
                        class="prose text-secondary text-[18px] max-[720px]:text-[18px] leading-[1.7]"
                    >
                        <slot />
                    </div>

                    <div class="mt-12 pt-8 border-t border-border">
                        <p
                            class="text-secondary text-[14px] mb-4 uppercase tracking-widest font-bold"
                        >
                            Share this article
                        </p>
                        <div class="flex gap-4">
                            <a
                                href={blueskyShare}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-secondary hover:text-primary transition-colors"
                                aria-label="Share on Bluesky"
                            >
                                <svg
                                    width="22"
                                    height="22"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    xmlns="http://www.w3.org/2000/svg"
                                    style="vertical-align: middle;"
                                >
                                    <path
                                        d="M16.4927 13.4515C16.3689 13.4365 16.2414 13.4215 16.1177 13.4027C16.2452 13.4177 16.3689 13.4365 16.4927 13.4515ZM12.0002 10.9165C11.0214 9.01524 8.35895 5.47149 5.88395 3.72399C3.5102 2.04774 2.60645 2.33649 2.0102 2.60649C1.32395 2.91774 1.2002 3.97149 1.2002 4.59024C1.2002 5.20899 1.54145 9.67524 1.7627 10.4215C2.49395 12.8852 5.10395 13.7177 7.5077 13.4477C7.63145 13.429 7.7552 13.414 7.8827 13.3952C7.75895 13.414 7.6352 13.4327 7.5077 13.4477C3.98645 13.9727 0.858945 15.2552 4.96145 19.819C9.4727 24.4915 11.1414 18.8177 12.0002 15.9415C12.8589 18.8177 13.8452 24.2852 18.9602 19.819C22.8002 15.9415 20.0139 13.969 16.4927 13.4477C16.3689 13.4327 16.2414 13.4177 16.1177 13.399C16.2452 13.414 16.3689 13.4327 16.4927 13.4477C18.8964 13.714 21.5027 12.8815 22.2377 10.4215C22.4589 9.67524 22.8002 5.21274 22.8002 4.59024C22.8002 3.96774 22.6764 2.91399 21.9902 2.60649C21.3977 2.34024 20.4902 2.04774 18.1202 3.72399C15.6414 5.47149 12.9789 9.01524 12.0002 10.9165Z"
                                        fill="currentColor"></path>
                                </svg>
                            </a>
                            <a
                                href={twitterShare}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-secondary hover:text-primary transition-colors text-[22px]"
                                aria-label="Share on X (Twitter)"
                            >
                                <i class="fa-brands fa-x-twitter"></i>
                            </a>
                            <a
                                href={facebookShare}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-secondary hover:text-primary transition-colors text-[22px]"
                                aria-label="Share on Facebook"
                            >
                                <i class="fa-brands fa-facebook"></i>
                            </a>
                            <a
                                href={linkedinShare}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-secondary hover:text-primary transition-colors text-[22px]"
                                aria-label="Share on LinkedIn"
                            >
                                <i class="fa-brands fa-linkedin"></i>
                            </a>
                            <button
                                id="copy-link"
                                class="text-secondary hover:text-primary transition-colors text-[22px] cursor-pointer bg-transparent border-none p-0"
                                aria-label="Copy link"
                            >
                                <i class="fa-regular fa-copy"></i>
                            </button>
                        </div>
                    </div>
                </article>
            </div>
        </main>

        <ScrollIndicator />
        <Footer />
    </body>
</html>

<style>
    .prose :global(h1) {
        font-size: 36px;
        font-weight: bold;
        line-height: 1.1;
        color: #d1d8ff;
    }

    .prose :global(h2) {
        font-size: 28px;
        font-weight: bold;
        line-height: 1.1;
        color: #d1d8ff;
        padding-top: 32px;
    }

    .prose :global(h3) {
        font-size: 22px;
        font-weight: bold;
        line-height: 1.2;
        color: #b8c0e8;
        padding-top: 24px;
    }

    .prose :global(h4) {
        font-size: 20px;
        font-weight: bold;
        line-height: 1.3;
        color: #b8c0e8;
    }

    .prose :global(h5) {
        font-size: 16px;
        font-weight: bold;
        line-height: 1.4;
        color: #9aa0c4;
    }

    .prose :global(h6) {
        font-size: 14px;
        font-weight: bold;
        line-height: 1.4;
        color: #9aa0c4;
    }

    .prose :global(p) {
        margin-bottom: 16px;
    }

    .prose :global(strong) {
        color: #d1d8ff;
    }

    .prose :global(hr) {
        padding-top: 24px;
        padding-bottom: 24px;
    }

    .prose :global(img) {
        padding-bottom: 12px;
        border-radius: 0px;
    }

    .prose :global(* + p:has(img)) {
        padding-top: 48px;
    }

    .prose :global(li) {
        margin-bottom: 12px;
    }

    .prose :global(a) {
        text-decoration: none;
    }

    .prose :global(a:hover) {
        text-decoration: underline;
        color: var(--accent);
    }
</style>

<script>
    const btn = document.getElementById("copy-link");
    if (btn) {
        btn.addEventListener("click", () => {
            navigator.clipboard.writeText(window.location.href).then(() => {
                const icon = btn.querySelector("i");
                if (icon) {
                    icon.className = "fa-regular fa-circle-check";
                    setTimeout(() => {
                        icon.className = "fa-regular fa-copy";
                    }, 2000);
                }
            });
        });
    }
</script>
