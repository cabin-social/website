---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import ScrollIndicator from "../../components/ScrollIndicator.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";

const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html
    lang="en"
    class="h-screen overflow-hidden max-[900px]:h-auto max-[900px]:overflow-auto"
>
    <head>
        <BaseHead
            title={`Blog — ${SITE_TITLE}`}
            description={SITE_DESCRIPTION}
        />
    </head>
    <body class="bg-bg h-full flex flex-col max-[900px]:h-auto">
        <Header />
        <main
            class="flex-1 min-h-0 w-full max-w-[1280px] mx-auto flex flex-col"
        >
            <div
                class="flex-1 min-h-0 overflow-y-auto py-16 px-16 max-[900px]:px-6 max-[600px]:px-5"
            >
                <div class="max-w-[600px] mx-auto flex flex-col gap-8">
                    <div class="flex flex-col gap-2">
                        <h1
                            class="font-bold text-[44px] leading-[1.1] text-primary m-0 max-[900px]:text-[32px] max-[600px]:text-[26px]"
                        >
                            Blog
                        </h1>
                        <p class="text-secondary text-[20px] leading-[1.5] m-0">
                            This blog is for announcements, updates, and our
                            completely random thoughts...of which we have many.
                        </p>
                    </div>
                    <ul class="list-none m-0 p-0 flex flex-col gap-6">
                        {
                            posts.map((post) => (
                                <li class="border-b border-border pb-6 last:border-b-0">
                                    <a
                                        href={`/blog/${post.id}/`}
                                        class="block group no-underline"
                                    >
                                        {post.data.heroImage && (
                                            <img
                                                src={post.data.heroImage.src}
                                                alt=""
                                                class="w-full rounded-lg object-fill mb-4"
                                                style="min-height: 400px; max-height: 600px;"
                                            />
                                        )}
                                        <p class="text-secondary text-[16px] m-0 mb-1">
                                            <FormattedDate
                                                date={post.data.pubDate}
                                            />
                                        </p>
                                        <h2 class="text-primary font-bold text-[28px] leading-snug m-0 mb-2 transition-colors group-hover:text-accent">
                                            {post.data.title}
                                        </h2>
                                        {post.data.description && (
                                            <p class="text-secondary text-[18px] leading-relaxed m-0">
                                                {post.data.description}
                                            </p>
                                        )}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </main>
        <ScrollIndicator />
        <Footer />
    </body>
</html>
